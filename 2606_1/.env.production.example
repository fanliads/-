AI_PRIORITY_RETRY_MAX=1
AI_PRIORITY_MAX_TOKENS=800
WECOM_NOTIFICATION_ENABLED=false
WECOM_NOTIFICATION_WEBHOOK_URL=
WECOM_NOTIFICATION_TIMEOUT_MS=3000
